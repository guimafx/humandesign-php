APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=America/Sao_Paulo

# Drivers válidos: demo, swiss, strict
# demo   = permite testar a interface com dados não confiáveis
# swiss  = usa o Swiss Ephemeris para cálculos astronômicos reais
# strict = bloqueia cálculo sem efemérides reais
EPHEMERIS_DRIVER=demo

SWETEST_BIN=/usr/local/bin/swetest
SWISSEPH_EPHE_PATH=/usr/local/share/swisseph/ephe
