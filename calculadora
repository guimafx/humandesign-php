<?php
require_once "HumanDesignUltimate.php";

function geo($cidade)
{
    $url="https://geocoding-api.open-meteo.com/v1/search?name=".urlencode($cidade)."&count=1";
    $j=json_decode(file_get_contents($url),true);

    return [
        'lat'=>$j['results'][0]['latitude'],
        'lon'=>$j['results'][0]['longitude']
    ];
}

$result=null;
$svg=null;

if($_POST)
{
    $geo=geo($_POST['cidade']);

    $hd=new HumanDesignUltimate();

    $result=$hd->calculate([
        'year'=>$_POST['ano'],
        'month'=>$_POST['mes'],
        'day'=>$_POST['dia'],
        'hour'=>$_POST['hora'] ?? 12,
        'minute'=>$_POST['minuto'] ?? 0,
        'timezone'=>-3,
        'lat'=>$geo['lat'],
        'lon'=>$geo['lon'],
        'unknown_time'=>isset($_POST['unknown_time'])
    ]);

    $svg=$hd->renderMandala($result);
}
